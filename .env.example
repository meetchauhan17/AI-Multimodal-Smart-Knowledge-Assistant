# ─────────────────────────────────────────────────────────────────────────────
# AI Multimodal Smart Knowledge Assistant — environment variables
# Copy this file to .env and fill in your real values.  Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────



# ── Groq (fast inference — first fallback) ───────────────────────────────────
# Sign up at https://console.groq.com/ and create a free API key.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ── Google Gemini (second fallback) ──────────────────────────────────────────
# Enable Generative Language API in Google Cloud Console, then create a key at
# https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest
GEMINI_VISION_MODEL=gemini-flash-latest

# ── LLM provider routing ─────────────────────────────────────────────────────
# Comma-separated preference order; first healthy provider wins.
PRIMARY_PROVIDER=gemini
FALLBACK_ORDER=gemini,groq

# ── Image generation ─────────────────────────────────────────────────────────
# Pollinations.ai requires no key — safe free default.
# Pattern: https://image.pollinations.ai/prompt/{prompt}
IMAGE_GEN_FALLBACK_URL=https://image.pollinations.ai/prompt/{prompt}

# ── Paths (optional overrides) ───────────────────────────────────────────────
KNOWLEDGE_BASE_DIR=data/knowledge_base
CHROMA_PERSIST_DIR=data/chroma_db
LOG_DIR=logs
