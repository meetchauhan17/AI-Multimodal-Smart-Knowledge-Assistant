# ─────────────────────────────────────────────────────────────────────────────
# AI Multimodal Smart Knowledge Assistant — environment variables
# Copy this file to .env and fill in your real values.  Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Bob Shell (primary LLM gateway) ─────────────────────────────────────────
# Obtain your key from the Bob Shell developer portal or your IBM account page.
# BOBSHELL_API_KEY is the canonical name used throughout this project.
# The older name BOB_API_KEY is also accepted as a silent fallback (see shared/bob.py).
BOBSHELL_API_KEY=your_bobshell_api_key_here
# BOB_API_KEY=your_bobshell_api_key_here   # legacy fallback — same key, older name

# Default model sent to the bob CLI (can be overridden per-call).
BOB_MODEL=ibm/granite-3-8b-instruct

# Set to 1 to print full prompts/responses to stderr for debugging.
BOB_DEBUG=0

# ── Groq (fast inference — first fallback) ───────────────────────────────────
# Sign up at https://console.groq.com/ and create a free API key.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ── Google Gemini (second fallback) ──────────────────────────────────────────
# Enable Generative Language API in Google Cloud Console, then create a key at
# https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest
GEMINI_VISION_MODEL=gemini-flash-latest

# ── LLM provider routing ─────────────────────────────────────────────────────
# Comma-separated preference order; first healthy provider wins.
PRIMARY_PROVIDER=bob
FALLBACK_ORDER=bob,groq,gemini

# ── Image generation ─────────────────────────────────────────────────────────
# Pollinations.ai requires no key — safe free default.
# Pattern: https://image.pollinations.ai/prompt/{prompt}
IMAGE_GEN_FALLBACK_URL=https://image.pollinations.ai/prompt/{prompt}

# ── Paths (optional overrides) ───────────────────────────────────────────────
KNOWLEDGE_BASE_DIR=data/knowledge_base
CHROMA_PERSIST_DIR=data/chroma_db
LOG_DIR=logs
